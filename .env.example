# === Обязательные ===
TENRI_BOT_TOKEN=            # токен от @BotFather (отдельный бот!)
TENRI_GROUP_ID=             # id закрытой группы, например -1001234567890 (бот должен быть админом)
TENRI_ADMIN_IDS=            # telegram_id админов через запятую: 111111111,222222222

# === Опциональные ===
# Локально можно оставить как есть. На Railway укажите путь ВНУТРИ подключённого Volume,
# например /data/tenribot.db, и примонтируйте том на /data — иначе БД сотрётся при redeploy.
TENRI_DB_PATH=data/tenribot.db
TENRI_TIMEZONE=Asia/Almaty
TENRI_SITE_URL=https://baqsy.tnriazun.com

# Интеграция с сайтом на VPS (если пусто — бот работает автономно)
TENRI_PLATFORM_URL=         # https://baqsy.tnriazun.com
TENRI_PLATFORM_TOKEN=       # значение BOT_API_SECRET из .env Django-бэкенда

# AI-ассистент — основной провайдер Google Gemini (ключ: https://aistudio.google.com/apikey)
# Если оба ключа пусты — режим ассистента выключен. OpenAI — автоматический резерв.
TENRI_AI_PROVIDER=gemini
TENRI_GEMINI_API_KEY=
TENRI_GEMINI_MODEL=gemini-2.0-flash
TENRI_OPENAI_API_KEY=
TENRI_OPENAI_MODEL=gpt-4o-mini
TENRI_ASSISTANT_DAILY_LIMIT=30        # сообщений на лида в сутки
TENRI_ASSISTANT_HISTORY_WINDOW=10     # окно контекста диалога
TENRI_AI_DAILY_TOKEN_BUDGET=200000    # глобальный дневной бюджет токенов (0 = без лимита)

# === Railway ===
# PORT Railway задаёт сам — health-эндпоинт поднимется на нём автоматически, ставить не нужно.
# Обязательно подключите Volume на /data и задайте TENRI_DB_PATH=/data/tenribot.db.
